<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorAccent">@color/colorAccent</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">?attr/isLightTheme</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenBackground">?android:attr/windowBackground</item>
        <item name="postSplashScreenTheme">@style/AppTheme</item>
    </style>

    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppTheme.NoActionBar.Modal" parent="AppTheme.NoActionBar">
        <item name="android:windowAnimationStyle">@style/Animation.Activity.BottomUp</item>
    </style>

    <!-- Animation Style -->
    <style name="Animation.Activity.BottomUp" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_bottom</item>
        <item name="android:activityOpenExitAnimation">@anim/no_animation</item>
        <item name="android:activityCloseEnterAnimation">@anim/no_animation</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_bottom</item>
    </style>

    <!-- Modal Theme -->
    <style name="AppTheme.Modal" parent="AppTheme">
        <item name="android:windowAnimationStyle">@style/Animation.Activity.BottomUp</item>
    </style>

    <!-- Bento card Theme -->

    <style name="BentoCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/card_background_color</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="BentoCard.Outline">
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/color_primary_semi_opaq</item>
    </style>

    <style name="BentoCard.Outline.Primary">
        <item name="strokeColor">@color/colorPrimary</item>
    </style>

    <style name="BentoLabel">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">#99E5E2E1</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <style name="BentoValue">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">28sp</item>
    </style>

    <style name="BentoValue.Large">
        <item name="android:textSize">48sp</item>
    </style>

    <style name="BentoGenreText">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <!-- Selector Theme -->
    <style name="BentoSelector" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxBackgroundColor">@color/card_background_color</item>
        <item name="boxStrokeColor">@color/colorPrimary</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="hintEnabled">false</item>
        <item name="endIconTint">@color/white</item>
    </style>

    <style name="BentoSelectorText">
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <style name="BentoChip" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_background_color</item>
        <item name="android:textColor">@color/white</item>
        <item name="chipCornerRadius">16dp</item>
        <item name="chipStartPadding">12dp</item>
        <item name="chipEndPadding">12dp</item>
        <item name="chipMinHeight">48dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipStrokeColor">@color/color_primary_semi_opaq</item>
        <item name="rippleColor">@color/colorPrimary</item>
    </style>

    <style name="BentoIconButton" parent="Widget.MaterialComponents.Button.OutlinedButton.Icon">
        <item name="backgroundTint">@color/chip_background_color</item>
        <item name="iconTint">@color/white</item>
        <item name="cornerRadius">16dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/color_primary_semi_opaq</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">48dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="iconPadding">0dp</item>
        <item name="iconGravity">textStart</item>
        <item name="rippleColor">@color/colorPrimary</item>
    </style>
</resources>
