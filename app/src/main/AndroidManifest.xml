<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity
            android:name="fr.eseo.dis.amiaudluc.spinoffapp.ui.MainActivity"
            android:label="@string/app_name"
            android:theme="@style/Theme.App.Starting"
            android:exported="true">
            <intent-filter>
                <category android:name="android.intent.category.LAUNCHER" />
                <action android:name="android.intent.action.MAIN" />
            </intent-filter>
        </activity>
        <activity
            android:name="fr.eseo.dis.amiaudluc.spinoffapp.ui.movies.MovieActivity"
            android:label="@string/title_activity_movie"
            android:theme="@style/AppTheme.NoActionBar"
            android:exported="false"/>
        <activity
            android:name="fr.eseo.dis.amiaudluc.spinoffapp.ui.series.SerieActivity"
            android:label="@string/title_activity_serie"
            android:theme="@style/AppTheme.NoActionBar"
            android:exported="false" />
        <activity
            android:name="fr.eseo.dis.amiaudluc.spinoffapp.ui.season.SeasonActivity"
            android:theme="@style/AppTheme"
            android:exported="false" />
        <activity
            android:name="fr.eseo.dis.amiaudluc.spinoffapp.ui.artists.ArtistActivity"
            android:theme="@style/AppTheme"
            android:exported="false" />
        <activity
            android:name="fr.eseo.dis.amiaudluc.spinoffapp.ui.episode.EpisodeActivity"
            android:theme="@style/AppTheme"
            android:exported="false" />
        <activity
            android:name="fr.eseo.dis.amiaudluc.spinoffapp.ui.library.MediaListActivity"
            android:label="@string/title_library"
            android:theme="@style/AppTheme"
            android:exported="false" />
        <activity
            android:name="fr.eseo.dis.amiaudluc.spinoffapp.ui.library.MovieStatsActivity"
            android:label="@string/stats_movie_title"
            android:theme="@style/AppTheme"
            android:exported="false" />
        <activity
            android:name="fr.eseo.dis.amiaudluc.spinoffapp.ui.library.SerieStatsActivity"
            android:label="@string/stats_serie_title"
            android:theme="@style/AppTheme"
            android:exported="false" />
    </application>

</manifest>
